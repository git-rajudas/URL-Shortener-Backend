<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body id="linksPage">



    <div class="main">
        <div class="menu">
            <a id="createLinkbtn" href="/">Create Short Link</a>
            <a id="viewLink" href="/links">View Your Links</a>
        </div>
        <div class="container" id="createdLink">
            <% if (locals.urls) { %>
                <table class="styled-table">
                    <thead>
                        <th>S. No</th>
                        <th>Short URL</th>
                        <th>Redirect URL</th>
                        <th>Clicks</th>
                    </thead>
                    <tbody>
                        <% urls.forEach((url,index)=> { %>
                            <tr>
                                <td>
                                    <%= index+1 %>
                                </td>
                                <td>
                                    <a target="_blank" href="/url/<%= url.shortId %>">Hit.link/<%= url.shortId %></a>
                                    <!-- <%= url.shortId %> -->
                                </td>
                                <td>
                                    <%= url.redirectURL %>
                                </td>
                                <td>
                                    <%= url.visitHistory.length %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>
        </div>
    </div>

</body>

</html>